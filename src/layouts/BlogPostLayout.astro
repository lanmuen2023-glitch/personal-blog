---
import type { CollectionEntry } from "astro:content";
import TagBadge from "../components/TagBadge.astro";

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
---

<header class="mb-8">
  <h1 class="text-3xl font-bold">{post.data.title}</h1>
  <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-gray-500">
    <time datetime={post.data.pubDate.toISOString()}>
      {post.data.pubDate.toLocaleDateString("en-US", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })}
    </time>
    {post.data.updatedDate && (
      <span>
        Updated: {
          post.data.updatedDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
    )}
    {post.data.category && (
      <span
        class="px-2 py-0.5 rounded bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200 text-xs"
      >
        {post.data.category}
      </span>
    )}
  </div>
  <div class="flex flex-wrap gap-2 mt-3">
    {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
  </div>
</header>

<slot />
